    "scrypted-deploy": "scrypted-deploy"
  },
  "scrypted": {
    "name": "Scrix Camera Discovery",
    "type": "API",
    "interfaces": [
      "HttpRequestHandler",
      "DeviceProvider",
      "Settings"
    ]
