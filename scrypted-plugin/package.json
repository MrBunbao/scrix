{
  "name": "scrypted-scrix",
  "version": "1.0.0",
  "description": "Scrix — camera stream discovery bridge for Scrypted NVR",
  "keywords": ["scrypted", "camera", "discovery", "nvr", "rtsp"],
  "author": "MrBunbao",
  "license": "MIT",
  "scripts": {
